# ─── Discord ───────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
BOT_TOKEN=

# Server (guild) ID — right-click your server icon → Copy Server ID
GUILD_ID=

# ─── Analytics Settings ────────────────────────────────────────────────────
# How often to collect stats (cron expression, default: every 30 minutes)
ANALYTICS_CRON=*/30 * * * *

# How many recent messages to scan per channel (max 200 recommended)
MESSAGE_FETCH_LIMIT=200

# ─── Firebase (DA Ops Hub Integration) ────────────────────────────────────
# Stats are pushed here and read by the Discord Intel tab in your ops hub.
#
# FIREBASE_DATABASE_URL → Firebase Console → Project Settings → General
#   Format: https://<project-id>-default-rtdb.firebaseio.com
#
# FIREBASE_DB_SECRET → Firebase Console → Project Settings →
#   Service Accounts → Database Secrets → Show
FIREBASE_DATABASE_URL=
FIREBASE_DB_SECRET=
